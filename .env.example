# SMTP credentials for the contact form (set these in .env.local for production)
SMTP_HOST=mail.weload.eu
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=office@weload.eu
SMTP_PASSWORD=

# Where contact-form submissions are delivered
CONTACT_TO=office@weload.eu
# From address used by the mailer (usually the same as SMTP_USER)
CONTACT_FROM=office@weload.eu

# CRM integration — when CRM_WEBHOOK_URL is set, each contact-form lead is POSTed
# here as JSON. This becomes the primary destination; email (above) stays as an
# optional best-effort copy. Leave CRM_WEBHOOK_URL empty to use email only.
CRM_WEBHOOK_URL=
# Shared secret sent to the CRM as: Authorization: Bearer <CRM_API_KEY>
CRM_API_KEY=
